<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <configSections>
    <section name="commonParameters" type="section"/>
    <section name="logParameters" type="section"/>
    <section name="databaseParameters" type="section"/>
  </configSections>
  <commonParameters>
    <Version value="V2.10"/>
    <Environment value="aplusco"/>
  </commonParameters>
  <logParameters>
    <LogFilePath value="C:\TayqaSale\logs\{environment}\{version}\tayqasaleMasterDataSync.txt"/>
    <LogLevel value="2"/>
    <FileSizeInMB value="10"/>
  </logParameters>
  <databaseParameters>
    <TayqaSaleDB value="Server=192.168.80.23;Database=TayqaSale;User ID=tayqa;Password=t@yq@2!016;Trusted_Connection=false; Connection Timeout=60"/>
    <ErpDB value="Server=192.168.80.22;Database=TigerDb;User ID=tayqa;Password=t@yq@2!016;Trusted_Connection=false; Connection Timeout=60"/>
  </databaseParameters>
  <additionalParameters>
    <RoundDepthForDecimal value="4"/>
    <ERP value="TigerEnterprise"/>
    <AuthTokenValidationEndpoint value="http://192.168.80.25:1102/tayqa/tiger/api/{environment}/v2.91/uid/CheckUser"/>
    <TigerSyncRefreshStartPeriod value="01.01.2000 00:00:00"/>
    <TigerQueryFilterForItems value=" AND ITEM.CARDTYPE IN (1,2,3,12)"/>
    <TigerQueryFilterForClients value=" AND CLCARD.CARDTYPE IN (3,4)"/>
    <TigerQueryFilterForPrices value=" AND PRC.PTYPE=2 AND PRC.GRPCODE='STD'"/>
    <TigerClientRouteType value="CLCARD"/>
	<IgnorePermittedClientTable value="true"/>
  </additionalParameters>
</configuration>