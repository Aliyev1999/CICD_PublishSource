<?xml version="1.0"?>
<configuration>
  <configSections>
    <section name="commonParameters" type="section"/>
    <section name="logParameters" type="section"/>
    <section name="databaseParameters" type="section"/>
  </configSections>
  <commonParameters>
    <Environment value="prod"/>
    <Version value="v2.92"/>
  </commonParameters>
  <logParameters>
    <LogFilePath value="C:\logs\{environment}\RequestProcessor\{version}\requestProcessor.txt"/>
    <LogLevel value="2"/>
    <FileSizeInMB value="10"/>
  </logParameters>
  <databaseParameters>
    <TayqaSaleDB value="Server=192.168.10.18;Database=TayqaSale;User ID=tayqa;Password=t@yq@2!016;Trusted_Connection=false; Connection Timeout=60"/>
	<TayqaSaleDbSecondary value="Server=192.168.10.18;Database=TayqaSale;User ID=tayqa;Password=t@yq@2!016;Trusted_Connection=false; Connection Timeout=60"/>
  </databaseParameters>
  <additionalParameters>
    <RouteDaysBefore value="14"/>
    <RouteDaysAfter value="31"/>
	<RestoreOperationDays value="30"/>	
	<DeliveryConsiderMasterDataDays value="30"/>
    <CatalogImagesPath value="D:\TayqaSale\AppDownloads\{environment}\ImageZips\"/>
	<ERPIntegratorVersion value="V1.10"/>	
	<SalesmanSource value="UserSalesmanMapping"/>
	<UseMasterDataTimeStamp value="false"/>
  </additionalParameters>
</configuration>
