<?xml version="1.0"?>
<configuration>
  <configSections>
    <section name="commonParameters" type="section"/>
    <section name="logParameters" type="section"/>
    <section name="databaseParameters" type="section"/>
  </configSections>
  <commonParameters>
    <Environment value="avrora"/>
    <Version value="V1.00"/>
  </commonParameters>
  <logParameters>
    <LogFilePath value="C:\logs\{environment}\InternalProcessing\{version}\internalProcessingService.txt"/>
    <LogLevel value="2"/>
    <FileSizeInMB value="10"/>
  </logParameters>
  <databaseParameters>
    <TayqaSaleDB value="Server=192.168.10.18;Database=TayqaSale;User ID=tayqa;Password=t@yq@2!016;Trusted_Connection=false; Connection Timeout=60"/>
  </databaseParameters>
  <additionalParameters>
    <Firm value="100"/>
    <ActivePeriod value="1"/>
    <Step value="20"/>
    <RefreshItemStockMethodId value="21"/>    
    <MaximumTryCounterForService value="10"/>
    <LogProcessingResult value="true"/>    
    <ExtraWhereClauseAndOrderByFilter value="AND DocType IN (0,1,2,3,4,5) ORDER BY DocType DESC"/>    
  </additionalParameters>
</configuration>
